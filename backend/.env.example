DATABASE_URL=postgresql+psycopg://pantheon:pantheon@localhost:5432/pantheon
SECRET_KEY=change-this-dev-secret
ACCESS_TOKEN_EXPIRE_MINUTES=480
KUBERNETES_MODE=dry-run
KUBECONFIG=
KUBERNETES_NAMESPACE_PREFIX=pantheon-lab
KUBERNETES_SERVICE_IMAGE=pantheon-fake-service:latest
KUBERNETES_RUNNER_IMAGE=pantheon-runner:latest
KUBERNETES_RUNNER_IMAGE_PULL_POLICY=IfNotPresent
KUBERNETES_JOB_TIMEOUT_SECONDS=120
KUBERNETES_FRONTEND_ORIGINS=http://localhost:8090,http://localhost:5173,http://localhost:3000
